{
  "name": "excalidraw-cli",
  "version": "1.0.0",
  "description": "Agent-first CLI for Excalidraw scene inspection, validation, and rendering",
  "type": "module",
  "bin": {
    "excal": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@excalidraw/utils": "^0.1.2",
    "@types/node": "^22.13.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "playwright": "^1.50.0",
    "@excalidraw/excalidraw": "^0.18.0"
  },
  "engines": {
    "node": ">=20"
  }
}
